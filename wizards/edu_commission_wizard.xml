<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view -->
    <record id="edu_commission_wizard_form" model="ir.ui.view">
        <field name="name">edu.commission.wizard.form</field>
        <field name="model">edu.commission.wizard</field>
        <field name="arch" type="xml">
            <form string="Comisión">
                <div class="oe_title">
                    <label for="name" string="Comisión" />
                    <h1>
                        <field name="name" placeholder="Ej. Comisión A"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="course_instance_id" readonly="1"/>
                        <field name="class_days"/>
                    </group>
                    <group>
                        <field name="start_hour" widget="float_time"/>
                        <field name="end_hour" widget="float_time"/>
                    </group>
                </group>
                <notebook>
                    <page name="Alumnos">
                        <field name="lines">
                            <list editable="bottom" create="0" delete="0">
                                <field name="student_id"/>
                                <field name="is_part"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button
                        string="Guardar Asistencia"
                        name="action_confirm"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        string="Cancelar"
                        special="cancel"
                        class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="edu_commission_wizard_action" model="ir.actions.act_window">
        <field name="name">Comision</field>
        <field name="res_model">edu.commission.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
