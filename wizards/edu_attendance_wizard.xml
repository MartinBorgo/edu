<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form view -->
    <record id="view_edu_attendance_wizard_form" model="ir.ui.view">
        <field name="name">edu.attendance.wizard.form</field>
        <field name="model">edu.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Asistencias">
                <div class="oe_title">
                    <label for="date" string="Clase"/>
                    <h1>
                        <field name="date" readonly="1"/>
                    </h1>
                </div>
                <notebook>
                    <page string="Alumnos">
                        <field name="lines">
                            <list editable="bottom" create="0" delete="0">
                                <field name="student_id"/>
                                <field name="assistance"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_confirm" string="Guardar Asistencia" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="edu_attendance_wizard_action" model="ir.actions.act_window">
        <field name="name">Registrar Asistencia</field>
        <field name="res_model">edu.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_course_instance_id': active_id}</field>
    </record>
</odoo>
