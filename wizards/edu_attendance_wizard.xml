<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form view -->
    <record id="view_edu_attendance_wizard_form" model="ir.ui.view">
        <field name="name">edu.attendance.wizard.form</field>
        <field name="model">edu.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Asistencias">
                <div class="oe_title">
                    <label for="date" string="Clase" />
                    <h1>
                       <field name="date" readonly="1" />
                    </h1>
                </div>
                <field name="course_instance_id" readonly="1" />
                <notebook>
                    <page string="Alumnos">
                        <field name="lines">
                            <list editable="bottom" create="0" delete="0">
                                <field name="student_id" readonly="1" force_save="1"/>
                                <field name="assistance"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button
                        string="Guardar Asistencia"
                        name="action_confirm"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        string="Cancelar"
                        special="cancel"
                        class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="edu_attendance_wizard_action" model="ir.actions.act_window">
        <field name="name">Registrar Asistencia</field>
        <field name="res_model">edu.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
