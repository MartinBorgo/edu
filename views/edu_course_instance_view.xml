<? xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form view -->
    <record id="edu_course_instance_form_view" model="ir.ui.view">
        <field name="name">edu.course.instance.form</field>
        <field name="model">edu.course.instance</field>
        <field name="arch" type="xml">
            <form string="Instancia de curso">
                <header>
                    <button name="%(edu.edu_attendance_wizard_action)d"
                            string="Registrar asistencia"
                            type="action"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Curso"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group id="root_group">
                        <group id="lvl_1_group">
                            <field name="season_id"/>
                            <field name="course_id"/>
                            <field name="period"/>
                        </group>
                    </group>
                </sheet>
                <notebook>
                    <page string="Alumnos">
                        <field name="student_ids">
                            <list editable="top">
                                <field name="name"/>
                                <field name="phone"/>
                                <field name="max_educative_level"/>
                            </list>
                        </field>
                    </page>
                    <page string="Clases">
                        <field name="class_ids"/>
                    </page>
                    <page string="Notas de estudiantes">
                        <field name="student_history_ids">
                            <list editable="top">
                                <field name="student_id"/>
                                <field name="student_state"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="edu_course_instance_list_view" model="ir.ui.view">
        <field name="name">edu.course.instance.list</field>
        <field name="model">edu.course.instance</field>
        <field name="arch" type="xml">
            <list string="Cursos en progreso">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="edu_course_instance_action" model="ir.actions.act_window">
        <field name="name">Habilitar curso</field>
        <field name="res_model">edu.course.instance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
