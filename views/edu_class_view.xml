<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view -->
    <record id="edu_class_form_view" model="ir.ui.view">
        <field name="name">edu.class.form.view</field>
        <field name="model">edu.class</field>
        <field name="arch" type="xml">
            <form string="Clase">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Asistencia" />
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <field name="course_instance_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Asistencias">
                            <field name="assistance_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="assistance"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
